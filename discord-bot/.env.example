# Same Turso database as the Next.js site - copy these two values from
# whatever you set DATABASE_URL / DATABASE_AUTH_TOKEN to on Vercel.
DATABASE_URL=libsql://your-db.turso.io
DATABASE_AUTH_TOKEN=

# From the Discord Developer Portal (discord.com/developers/applications) -
# your application's Bot tab (token) and General Information tab (client id).
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
